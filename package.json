{
  "name": "the-other-99-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:v2content": "node scripts/validate-v2-content.mjs",
    "validate:full": "npx tsx scripts/validateContent.ts",
    "audit:questions": "npx tsx scripts/auditQuestionBank.ts",
    "audit:axes": "npx tsx scripts/reportAxisCoverage.ts",
    "audit:duplicates": "npx tsx scripts/reportDuplicateQuestions.ts",
    "audit:reveals": "npx tsx scripts/reportRevealDosing.ts",
    "audit:patterns": "npx tsx scripts/reportPatternCoverage.ts",
    "audit:contradictions": "npx tsx scripts/reportContradictionCoverage.ts",
    "audit:all": "npm run audit:questions && npm run audit:axes && npm run audit:duplicates && npm run audit:reveals && npm run audit:patterns && npm run audit:contradictions",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npm run build && npx cap sync android",
    "mobile:open:android": "npx cap open android",
    "mobile:add:android": "npx cap add android",
    "mobile:doctor": "npx cap doctor",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:bundle": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@supabase/supabase-js": "^2.43.0",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "4.1.8",
    "jsdom": "29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "4.1.8"
  }
}
